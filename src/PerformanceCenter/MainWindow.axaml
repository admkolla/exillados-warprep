<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PerformanceCenter.MainWindow"
        Title="Performance Center"
        Width="1260"
        Height="840"
        MinWidth="1120"
        MinHeight="760"
        Background="#0B0F14">

  <Grid RowDefinitions="Auto,*" ColumnDefinitions="315,*">

    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#101722" Padding="22,16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="PERFORMANCE CENTER"
                     Foreground="#F9FAFB"
                     FontSize="28"
                     FontWeight="Bold"/>
          <TextBlock Text="Diagnóstico, otimização e manutenção segura do sistema"
                     Foreground="#9CA3AF"
                     FontSize="14"/>
        </StackPanel>

        <Border Grid.Column="1"
                Background="#2A1111"
                BorderBrush="#EF4444"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,8"
                VerticalAlignment="Center">
          <TextBlock Text="v3.4 • Professional Release"
                     Foreground="#FCA5A5"
                     FontWeight="Bold"/>
        </Border>
      </Grid>
    </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#0F172A" Padding="16">
      <ScrollViewer>
        <StackPanel Spacing="14">

          <Border Background="#111827" CornerRadius="16" Padding="16">
            <StackPanel Spacing="6">
              <TextBlock Text="Performance Center"
                         Foreground="#F9FAFB"
                         FontSize="22"
                         FontWeight="Bold"/>
              <TextBlock Text="Diagnóstico, otimização e manutenção segura do sistema."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="📊 DASHBOARD"
                         Foreground="#FCA5A5"
                         FontWeight="Bold"
                         FontSize="13"/>

              <Button Content="⚙️ Otimização Recomendada"
                      Click="OnPrepararClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="🌐 REDE"
                         Foreground="#93C5FD"
                         FontWeight="Bold"
                         FontSize="13"/>

              <StackPanel Spacing="6">
                <TextBlock Text="Tipo de exame"
                           Foreground="#F9FAFB"
                           FontWeight="Bold"/>
                <ComboBox x:Name="ModoTesteCombo"
                          SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                  <ComboBoxItem Content="Curto — rápido"/>
                  <ComboBoxItem Content="Médio — recomendado"/>
                  <ComboBoxItem Content="Longo — diagnóstico detalhado"/>
                </ComboBox>
                <TextBlock Text="Curto: rápido. Médio: confiável. Longo: melhor para investigar instabilidade."
                           Foreground="#94A3B8"
                           TextWrapping="Wrap"
                           FontSize="12"/>
              </StackPanel>

              <Button Content="🔎 Verificação Geral"
                      Click="OnDiagnosticarClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="🖥️ HARDWARE E SENSORES"
                         Foreground="#86EFAC"
                         FontWeight="Bold"
                         FontSize="13"/>

              <Button Content="🖥️ Diagnóstico de Hardware"
                      Click="OnDiagnosticoGamerClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="🌡️ Temperaturas"
                      Click="OnTemperaturasClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="⚙️ OTIMIZAÇÃO"
                         Foreground="#FDE68A"
                         FontWeight="Bold"
                         FontSize="13"/>

              <Button Content="📋 Analisar Processos"
                      Click="OnFecharAppsClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="✅ Encerrar Selecionados"
                      Click="OnFecharSelecionadosClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="🧹 Limpeza Segura"
                      Click="OnLimparTempClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="🎮 Otimizações do Windows"
                      Click="OnModoJogoClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="⚡ Plano de Alto Desempenho"
                      Click="OnEnergiaClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="↩ Restaurar Configurações"
                      Click="OnRestaurarClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="🩺 INTEGRIDADE DO WINDOWS"
                         Foreground="#F9A8D4"
                         FontWeight="Bold"
                         FontSize="13"/>

              <Button Content="🩺 Verificar Windows"
                      Click="OnVerificarWindowsClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="🔧 Reparar Windows"
                      Click="OnRepararWindowsClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="🕵️ SEGURANÇA"
                         Foreground="#C4B5FD"
                         FontWeight="Bold"
                         FontSize="13"/>

              <Button Content="🕵️ Análise de Processos"
                      Click="OnProcessosSuspeitosClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="📁 RELATÓRIOS TÉCNICOS"
                         Foreground="#67E8F9"
                         FontWeight="Bold"
                         FontSize="13"/>

              <Button Content="📋 Copiar Relatório Técnico"
                      Click="OnCopiarRelatorioClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="💾 Salvar Relatório Técnico"
                      Click="OnSalvarRelatorioClick"
                      Height="42"
                      FontSize="14"/>

              <Button Content="📁 Abrir Relatórios Técnicos"
                      Click="OnAbrirRelatoriosClick"
                      Height="42"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Border Background="#111827" CornerRadius="14" Padding="14">
            <StackPanel Spacing="7">
              <TextBlock Text="Princípios do produto"
                         Foreground="#F9FAFB"
                         FontWeight="Bold"/>
              <TextBlock Text="✅ Gratuito" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Open-source" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Seguro" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Reversível" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Transparente" Foreground="#CBD5E1"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>
<ScrollViewer Grid.Row="1" Grid.Column="1">
      <StackPanel Margin="24" Spacing="18">

        <Border Background="#111827" CornerRadius="18" Padding="22">
          <StackPanel Spacing="8">
                                                <Border Background="#0B1220" CornerRadius="20" Padding="18" Margin="0,0,0,14">
              <StackPanel Spacing="16">

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Dashboard"
                               Foreground="#F8FAFC"
                               FontSize="25"
                               FontWeight="Bold"/>
                    <TextBlock Text="Painel rápido com métricas de rede, sensores, memória e integridade."
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"
                               FontSize="13"/>
                  </StackPanel>

                  <Button Grid.Column="1"
                          Content="Atualizar painel"
                          Click="OnDashboardRefreshClick"
                          Height="42"
                          Padding="18,0"
                          FontSize="14"/>

                  <Button Grid.Column="2"
                          Content="Verificação geral"
                          Click="OnDiagnosticarClick"
                          Height="42"
                          Padding="18,0"
                          FontSize="14"/>
                </Grid>

                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="10">

                  <Button Grid.Column="0"
                          Click="OnDiagnosticarClick"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Background="#111827" CornerRadius="16" Padding="14" MinHeight="122">
                      <StackPanel Spacing="7">
                        <TextBlock Text="REDE"
                                   Foreground="#38BDF8"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <TextBlock x:Name="DashboardRedeValorText"
                                   Text="-- ms"
                                   Foreground="#F8FAFC"
                                   FontSize="32"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Latência"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                        <Border Background="#0F2A3A" CornerRadius="8" Padding="8,4">
                          <TextBlock x:Name="DashboardRedeStatusText"
                                     Text="Clique para testar"
                                     Foreground="#7DD3FC"
                                     FontSize="12"
                                     HorizontalAlignment="Center"/>
                        </Border>
                      </StackPanel>
                    </Border>
                  </Button>

                  <Button Grid.Column="1"
                          Click="OnTemperaturasClick"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Background="#111827" CornerRadius="16" Padding="14" MinHeight="122">
                      <StackPanel Spacing="7">
                        <TextBlock Text="GPU"
                                   Foreground="#FDE68A"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <TextBlock x:Name="DashboardGpuValorText"
                                   Text="-- °C"
                                   Foreground="#F8FAFC"
                                   FontSize="32"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Temperatura"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                        <Border Background="#332B0B" CornerRadius="8" Padding="8,4">
                          <TextBlock x:Name="DashboardGpuStatusText"
                                     Text="Sensores"
                                     Foreground="#FDE68A"
                                     FontSize="12"
                                     HorizontalAlignment="Center"/>
                        </Border>
                      </StackPanel>
                    </Border>
                  </Button>

                  <Button Grid.Column="2"
                          Click="OnTemperaturasClick"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Background="#111827" CornerRadius="16" Padding="14" MinHeight="122">
                      <StackPanel Spacing="7">
                        <TextBlock Text="CPU"
                                   Foreground="#A7F3D0"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <TextBlock x:Name="DashboardCpuValorText"
                                   Text="-- %"
                                   Foreground="#F8FAFC"
                                   FontSize="32"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Uso atual"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                        <Border Background="#0B2F22" CornerRadius="8" Padding="8,4">
                          <TextBlock x:Name="DashboardCpuStatusText"
                                     Text="Monitorar"
                                     Foreground="#86EFAC"
                                     FontSize="12"
                                     HorizontalAlignment="Center"/>
                        </Border>
                      </StackPanel>
                    </Border>
                  </Button>

                  <Button Grid.Column="3"
                          Click="OnFecharAppsClick"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Background="#111827" CornerRadius="16" Padding="14" MinHeight="122">
                      <StackPanel Spacing="7">
                        <TextBlock Text="RAM"
                                   Foreground="#FCA5A5"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <TextBlock x:Name="DashboardRamValorText"
                                   Text="-- %"
                                   Foreground="#F8FAFC"
                                   FontSize="32"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Memória"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                        <Border Background="#3A1111" CornerRadius="8" Padding="8,4">
                          <TextBlock x:Name="DashboardRamStatusText"
                                     Text="Analisar processos"
                                     Foreground="#FCA5A5"
                                     FontSize="12"
                                     HorizontalAlignment="Center"/>
                        </Border>
                      </StackPanel>
                    </Border>
                  </Button>

                  <Button Grid.Column="4"
                          Click="OnVerificarWindowsClick"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Background="#111827" CornerRadius="16" Padding="14" MinHeight="122">
                      <StackPanel Spacing="7">
                        <TextBlock Text="WINDOWS"
                                   Foreground="#C4B5FD"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <TextBlock x:Name="DashboardWindowsValorText"
                                   Text="OK?"
                                   Foreground="#F8FAFC"
                                   FontSize="32"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Integridade"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                        <Border Background="#261B3D" CornerRadius="8" Padding="8,4">
                          <TextBlock x:Name="DashboardWindowsStatusText"
                                     Text="Verificar"
                                     Foreground="#C4B5FD"
                                     FontSize="12"
                                     HorizontalAlignment="Center"/>
                        </Border>
                      </StackPanel>
                    </Border>
                  </Button>

                </Grid>

                <Border Background="#07111F" CornerRadius="14" Padding="14">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="Otimização recomendada"
                                 Foreground="#F8FAFC"
                                 FontSize="17"
                                 FontWeight="Bold"/>
                      <TextBlock Text="Executa uma análise segura do sistema e mostra recomendações sem aplicar mudanças automáticas."
                                 Foreground="#94A3B8"
                                 TextWrapping="Wrap"
                                 FontSize="13"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Iniciar"
                            Click="OnPrepararClick"
                            Height="42"
                            Padding="22,0"
                            FontSize="14"/>
                  </Grid>
                </Border>

              </StackPanel>
            </Border>
            <TextBlock x:Name="StatusTitle"
                       Text="Quartel de preparação"
                       Foreground="#F9FAFB"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock x:Name="ResumoText"
                       Text="Escolha o tipo de exame e clique em Diagnosticar."
                       Foreground="#CBD5E1"
                       FontSize="15"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="390,*" ColumnSpacing="18">

          <Border Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="16">
              <TextBlock Text="Qualidade da rede"
                         Foreground="#F9FAFB"
                         FontSize="20"
                         FontWeight="Bold"/>

              <Border Background="#0B1220" CornerRadius="18" Padding="22">
                <StackPanel Spacing="12">
                  <TextBlock x:Name="GaugePingText"
                             Text="-- ms"
                             Foreground="#F9FAFB"
                             FontSize="46"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"/>

                  <TextBlock x:Name="GaugeStatusText"
                             Text="Aguardando exame"
                             Foreground="#CBD5E1"
                             FontSize="18"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             TextWrapping="Wrap"/>

                  <ProgressBar x:Name="GaugeQualityBar"
                               Minimum="0"
                               Maximum="100"
                               Value="0"
                               Height="28"
                               Foreground="#64748B"/>

                  <TextBlock x:Name="GaugeHintText"
                             Text="A barra mostra a qualidade aproximada do ping atual."
                             Foreground="#94A3B8"
                             FontSize="12"
                             TextWrapping="Wrap"
                             TextAlignment="Center"/>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border Background="#16351F" CornerRadius="10" Padding="8">
                  <TextBlock Text="0–70 ms&#10;Bom"
                             Foreground="#BBF7D0"
                             TextAlignment="Center"
                             FontSize="12"/>
                </Border>

                <Border Grid.Column="1" Background="#3A300D" CornerRadius="10" Padding="8">
                  <TextBlock Text="70–120 ms&#10;Atenção"
                             Foreground="#FEF08A"
                             TextAlignment="Center"
                             FontSize="12"/>
                </Border>

                <Border Grid.Column="2" Background="#3B1111" CornerRadius="10" Padding="8">
                  <TextBlock Text="120+ ms&#10;Ruim"
                             Foreground="#FECACA"
                             TextAlignment="Center"
                             FontSize="12"/>
                </Border>
              </Grid>

            </StackPanel>
          </Border>

          <Border Grid.Column="1" Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="12">
              <TextBlock Text="Painel ao vivo do teste"
                         Foreground="#F9FAFB"
                         FontSize="20"
                         FontWeight="Bold"/>

              <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <Border Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Alvo atual" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="AlvoAtualText"
                               Text="Aguardando"
                               Foreground="#E5E7EB"
                               FontSize="15"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Pacote" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="PacoteAtualText"
                               Text="0/0"
                               Foreground="#E5E7EB"
                               FontSize="20"
                               FontWeight="Bold"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Ping atual" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="PingAtualText"
                               Text="-- ms"
                               Foreground="#E5E7EB"
                               FontSize="22"
                               FontWeight="Bold"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Estado" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="EstadoAtualText"
                               Text="Parado"
                               Foreground="#E5E7EB"
                               FontSize="15"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </Grid>

              <ProgressBar x:Name="ProgressoBar"
                           Minimum="0"
                           Maximum="100"
                           Value="0"
                           Height="18"/>

              <TextBlock x:Name="ResumoAoVivoText"
                         Text="Nenhum exame em execução."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
          <Border Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="8">
              <TextBlock Text="Sistema"
                         Foreground="#F9FAFB"
                         FontSize="18"
                         FontWeight="Bold"/>
              <TextBlock x:Name="SistemaText"
                         Text="Aguardando diagnóstico..."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="8">
              <TextBlock Text="Rede"
                         Foreground="#F9FAFB"
                         FontSize="18"
                         FontWeight="Bold"/>
              <TextBlock x:Name="RedeText"
                         Text="Aguardando teste de ping/tracert..."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </Grid>

        <Border Background="#111827" CornerRadius="18" Padding="20">
          <StackPanel Spacing="10">
            <TextBlock Text="Tracert"
                       Foreground="#F9FAFB"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBox x:Name="TracertBox"
                     Text="Aguardando execução do tracert..."
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MinHeight="170"
                     Background="#0B1220"
                     Foreground="#E5E7EB"/>
          </StackPanel>
        </Border>

        <Border Background="#111827" CornerRadius="18" Padding="20">
          <StackPanel Spacing="10">
                        <Border Background="#0B1220" CornerRadius="14" Padding="12" Margin="0,0,0,12">
              <StackPanel Spacing="8">
                <TextBlock Text="Apps seguros encontrados"
                           Foreground="#F9FAFB"
                           FontWeight="Bold"/>

                <TextBlock x:Name="AppsSelecionaveisAvisoText"
                           Text="Clique em Listar Apps Seguros para carregar os candidatos."
                           Foreground="#94A3B8"
                           TextWrapping="Wrap"
                           FontSize="12"/>

                <StackPanel x:Name="AppsSelecionaveisPanel"
                            Spacing="6"/>
              </StackPanel>
            </Border>
                        <Border Background="#0B1220" CornerRadius="14" Padding="12" Margin="0,0,0,12">
              <StackPanel Spacing="8">
                <TextBlock Text="Classificação visual dos processos"
                           Foreground="#F9FAFB"
                           FontWeight="Bold"
                           FontSize="16"/>

                <TextBlock x:Name="ProcessosVisuaisAvisoText"
                           Text="Execute a otimização recomendada para classificar processos por impacto e segurança."
                           Foreground="#94A3B8"
                           TextWrapping="Wrap"
                           FontSize="12"/>

                <StackPanel x:Name="ProcessosVisuaisPanel"
                            Spacing="8"/>
              </StackPanel>
            </Border>
            <TextBlock Text="Relatório técnico"
                       Foreground="#F9FAFB"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBox x:Name="RelatorioBox"
                     Text="Exillados Performance Center v0.4.1 pronto. Nenhum diagnóstico executado ainda."
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MinHeight="300"
                     Background="#0B1220"
                     Foreground="#E5E7EB"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </Grid>
</Window>













































