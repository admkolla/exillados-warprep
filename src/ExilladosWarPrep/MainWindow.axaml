<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ExilladosWarPrep.MainWindow"
        Title="Exillados WarPrep"
        Width="1260"
        Height="840"
        MinWidth="1120"
        MinHeight="760"
        Background="#0B0F14">

  <Grid RowDefinitions="Auto,*" ColumnDefinitions="315,*">

    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#101722" Padding="22,16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="EXILLADOS WARPREP"
                     Foreground="#F9FAFB"
                     FontSize="28"
                     FontWeight="Bold"/>
          <TextBlock Text="Preparação segura, gratuita e open-source para Node War"
                     Foreground="#9CA3AF"
                     FontSize="14"/>
        </StackPanel>

        <Border Grid.Column="1"
                Background="#2A1111"
                BorderBrush="#EF4444"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,8"
                VerticalAlignment="Center">
          <TextBlock Text="v2.5.1 • Sensores corrigidos"
                     Foreground="#FCA5A5"
                     FontWeight="Bold"/>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Background="#0F172A" Padding="18">
      <ScrollViewer>
        <StackPanel Spacing="14">

          <Border Background="#111827" CornerRadius="16" Padding="16">
            <StackPanel Spacing="6">
              <TextBlock Text="🛡️ Exillados"
                         Foreground="#F9FAFB"
                         FontSize="22"
                         FontWeight="Bold"/>
              <TextBlock Text="Este programa não mexe no BDO, não é cheat, não coleta dados pessoais e tudo que alterar deverá ser reversível."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Background="#172033" CornerRadius="16" Padding="14">
            <StackPanel Spacing="8">
              <TextBlock Text="Tipo de exame de rede"
                         Foreground="#F9FAFB"
                         FontWeight="Bold"/>
              <ComboBox x:Name="ModoTesteCombo"
                        SelectedIndex="0"
                        HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Curto — rápido antes da Node"/>
                <ComboBoxItem Content="Médio — recomendado"/>
                <ComboBoxItem Content="Longo — diagnóstico detalhado"/>
              </ComboBox>
              <TextBlock Text="Curto: rápido. Médio: mais confiável. Longo: melhor para investigar instabilidade."
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"
                         FontSize="12"/>
            </StackPanel>
          </Border>

          <Button Content="🖥️ Diagnóstico Gamer"
                  Click="OnDiagnosticoGamerClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🌡️ Temperaturas"
                  Click="OnTemperaturasClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🕵️ Processos Suspeitos"
                  Click="OnProcessosSuspeitosClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🩺 Verificar Windows"
                  Click="OnVerificarWindowsClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🔧 Reparar Windows"
                  Click="OnRepararWindowsClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🔎 Diagnosticar PC e Rede"
                  Click="OnDiagnosticarClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="⚔️ Preparar para Guerra"
                  Click="OnPrepararClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🧹 Limpar Temporários Seguros"
                  Click="OnLimparTempClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="📋 Listar Apps Seguros"
                  Click="OnFecharAppsClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="✅ Fechar Apps Marcados"
                  Click="OnFecharSelecionadosClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="🎮 Ativar Modo Jogo"
                  Click="OnModoJogoClick"
                  Height="46"
                  FontSize="15"/>
          <Button Content="⚡ Energia Alto Desempenho"
                  Click="OnEnergiaClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="↩ Restaurar Configurações"
                  Click="OnRestaurarClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="📋 Copiar Relatório"
                  Click="OnCopiarRelatorioClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="💾 Salvar Relatório"
                  Click="OnSalvarRelatorioClick"
                  Height="46"
                  FontSize="15"/>

          <Button Content="📁 Abrir Relatórios"
                  Click="OnAbrirRelatoriosClick"
                  Height="46"
                  FontSize="15"/>

          <Border Background="#172033" CornerRadius="14" Padding="14" Margin="0,10,0,0">
            <StackPanel Spacing="7">
              <TextBlock Text="Princípios do projeto"
                         Foreground="#F9FAFB"
                         FontWeight="Bold"/>
              <TextBlock Text="✅ Gratuito" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Open-source" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Seguro" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Reversível" Foreground="#CBD5E1"/>
              <TextBlock Text="✅ Sem falcatrua" Foreground="#CBD5E1"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <ScrollViewer Grid.Row="1" Grid.Column="1">
      <StackPanel Margin="24" Spacing="18">

        <Border Background="#111827" CornerRadius="18" Padding="22">
          <StackPanel Spacing="8">
            <TextBlock x:Name="StatusTitle"
                       Text="Quartel de preparação"
                       Foreground="#F9FAFB"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock x:Name="ResumoText"
                       Text="Escolha o tipo de exame e clique em Diagnosticar."
                       Foreground="#CBD5E1"
                       FontSize="15"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="390,*" ColumnSpacing="18">

          <Border Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="16">
              <TextBlock Text="Qualidade da rede"
                         Foreground="#F9FAFB"
                         FontSize="20"
                         FontWeight="Bold"/>

              <Border Background="#0B1220" CornerRadius="18" Padding="22">
                <StackPanel Spacing="12">
                  <TextBlock x:Name="GaugePingText"
                             Text="-- ms"
                             Foreground="#F9FAFB"
                             FontSize="46"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"/>

                  <TextBlock x:Name="GaugeStatusText"
                             Text="Aguardando exame"
                             Foreground="#CBD5E1"
                             FontSize="18"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"
                             TextWrapping="Wrap"/>

                  <ProgressBar x:Name="GaugeQualityBar"
                               Minimum="0"
                               Maximum="100"
                               Value="0"
                               Height="28"
                               Foreground="#64748B"/>

                  <TextBlock x:Name="GaugeHintText"
                             Text="A barra mostra a qualidade aproximada do ping atual."
                             Foreground="#94A3B8"
                             FontSize="12"
                             TextWrapping="Wrap"
                             TextAlignment="Center"/>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border Background="#16351F" CornerRadius="10" Padding="8">
                  <TextBlock Text="0–70 ms&#10;Bom"
                             Foreground="#BBF7D0"
                             TextAlignment="Center"
                             FontSize="12"/>
                </Border>

                <Border Grid.Column="1" Background="#3A300D" CornerRadius="10" Padding="8">
                  <TextBlock Text="70–120 ms&#10;Atenção"
                             Foreground="#FEF08A"
                             TextAlignment="Center"
                             FontSize="12"/>
                </Border>

                <Border Grid.Column="2" Background="#3B1111" CornerRadius="10" Padding="8">
                  <TextBlock Text="120+ ms&#10;Ruim"
                             Foreground="#FECACA"
                             TextAlignment="Center"
                             FontSize="12"/>
                </Border>
              </Grid>

            </StackPanel>
          </Border>

          <Border Grid.Column="1" Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="12">
              <TextBlock Text="Painel ao vivo do teste"
                         Foreground="#F9FAFB"
                         FontSize="20"
                         FontWeight="Bold"/>

              <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <Border Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Alvo atual" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="AlvoAtualText"
                               Text="Aguardando"
                               Foreground="#E5E7EB"
                               FontSize="15"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Pacote" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="PacoteAtualText"
                               Text="0/0"
                               Foreground="#E5E7EB"
                               FontSize="20"
                               FontWeight="Bold"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Ping atual" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="PingAtualText"
                               Text="-- ms"
                               Foreground="#E5E7EB"
                               FontSize="22"
                               FontWeight="Bold"/>
                  </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#0B1220" CornerRadius="14" Padding="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Estado" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock x:Name="EstadoAtualText"
                               Text="Parado"
                               Foreground="#E5E7EB"
                               FontSize="15"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </Grid>

              <ProgressBar x:Name="ProgressoBar"
                           Minimum="0"
                           Maximum="100"
                           Value="0"
                           Height="18"/>

              <TextBlock x:Name="ResumoAoVivoText"
                         Text="Nenhum exame em execução."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
          <Border Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="8">
              <TextBlock Text="Sistema"
                         Foreground="#F9FAFB"
                         FontSize="18"
                         FontWeight="Bold"/>
              <TextBlock x:Name="SistemaText"
                         Text="Aguardando diagnóstico..."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Background="#111827" CornerRadius="18" Padding="20">
            <StackPanel Spacing="8">
              <TextBlock Text="Rede"
                         Foreground="#F9FAFB"
                         FontSize="18"
                         FontWeight="Bold"/>
              <TextBlock x:Name="RedeText"
                         Text="Aguardando teste de ping/tracert..."
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </Grid>

        <Border Background="#111827" CornerRadius="18" Padding="20">
          <StackPanel Spacing="10">
            <TextBlock Text="Tracert"
                       Foreground="#F9FAFB"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBox x:Name="TracertBox"
                     Text="Aguardando execução do tracert..."
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MinHeight="170"
                     Background="#0B1220"
                     Foreground="#E5E7EB"/>
          </StackPanel>
        </Border>

        <Border Background="#111827" CornerRadius="18" Padding="20">
          <StackPanel Spacing="10">
                        <Border Background="#0B1220" CornerRadius="14" Padding="12" Margin="0,0,0,12">
              <StackPanel Spacing="8">
                <TextBlock Text="Apps seguros encontrados"
                           Foreground="#F9FAFB"
                           FontWeight="Bold"/>

                <TextBlock x:Name="AppsSelecionaveisAvisoText"
                           Text="Clique em Listar Apps Seguros para carregar os candidatos."
                           Foreground="#94A3B8"
                           TextWrapping="Wrap"
                           FontSize="12"/>

                <StackPanel x:Name="AppsSelecionaveisPanel"
                            Spacing="6"/>
              </StackPanel>
            </Border>
            <TextBlock Text="Relatório para Discord"
                       Foreground="#F9FAFB"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBox x:Name="RelatorioBox"
                     Text="Exillados WarPrep v0.4.1 pronto. Nenhum diagnóstico executado ainda."
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MinHeight="300"
                     Background="#0B1220"
                     Foreground="#E5E7EB"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </Grid>
</Window>





























